# Grok Build Telegram Bridge configuration
# Copy to .env and fill values. Never commit .env or state files.

TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz-1234567

# Absolute path to the working directory for the Grok agent session
GROK_CWD=/root/projects/grok-build-telegram

# Path to the grok binary (defaults to grok in PATH or common locations)
GROK_BIN=/root/.grok/bin/grok

# Model to use with grok agent
GROK_MODEL=grok-build

# Directory for access.json, lock.json, health.json (will be created with 0700)
STATE_DIR=./.grok-telegram-state

# Set to "true" to auto-approve all ACP permissions (insecure; default false)
GROK_ALWAYS_APPROVE=false

# Optional timing overrides (milliseconds)
# PAIRING_EXPIRY_MS=300000
# PERMISSION_TIMEOUT_MS=300000
# PROMPT_STALE_AFTER_MS=900000
# STREAM_EDIT_INTERVAL_MS=1200
